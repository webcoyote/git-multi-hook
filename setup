#!/usr/bin/env bash
set -Eeuo pipefail
trap 'echo "${BASH_SOURCE[0]}: line $LINENO: $BASH_COMMAND: exitcode $?"' ERR
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Require git 2.54+ for configuration-based hook registration
GIT_VERSION="$(git --version | sed 's/git version //')"
GIT_MAJOR="${GIT_VERSION%%.*}"
GIT_MINOR="${GIT_VERSION#*.}"
GIT_MINOR="${GIT_MINOR%%.*}"
if [[ "$GIT_MAJOR" -lt 2 ]] || { [[ "$GIT_MAJOR" -eq 2 ]] && [[ "$GIT_MINOR" -lt 54 ]]; }; then
    echo >&2 "ERROR: git 2.54+ is required for configuration-based hooks (found $GIT_VERSION)"
    exit 1
fi

HOOKS=()
HOOKS+=(pre-commit)
HOOKS+=(prepare-commit-msg)
HOOKS+=(commit-msg)
HOOKS+=(post-commit)
HOOKS+=(pre-rebase)
HOOKS+=(post-checkout)
HOOKS+=(post-merge)
HOOKS+=(pre-push)
HOOKS+=(post-rewrite)
HOOKS+=(pre-merge-commit)
HOOKS+=(applypatch-msg)
HOOKS+=(pre-applypatch)
HOOKS+=(post-applypatch)
HOOKS+=(sendemail-validate)
HOOKS+=(pre-receive)
HOOKS+=(update)
HOOKS+=(post-receive)
HOOKS+=(post-update)
HOOKS+=(push-to-checkout)

# Ensure hook template is executable
HOOKS_DIR="$SCRIPT_DIR/hooks"
chmod +x "$HOOKS_DIR/__hook-template"

# Convert absolute path to ~ for display/config
HOOKS_PATH="${HOOKS_DIR/$HOME/\~}"

# For each hook type with a .d directory, create a symlink and register in global gitconfig
for hook in "${HOOKS[@]}"; do
    if [[ -d "$HOOKS_DIR/$hook.d" ]]; then
        # Create symlink so __hook-template knows its hook type via $0
        if [[ -n "${FORCE:-}" ]] || [[ ! -f "$HOOKS_DIR/$hook" ]]; then
            /bin/ln -sf "__hook-template" "$HOOKS_DIR/$hook"
        fi

        # Register in global gitconfig
        git config --global "hook.$hook.event" "$hook"
        git config --global "hook.$hook.command" "$HOOKS_PATH/$hook"
    fi
done
